{
  "name": "gestao-escolar",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:rules": "firebase emulators:exec --only firestore 'vitest run --passWithNoTests src/__tests__/rules/'",
    "test:e2e": "playwright test",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:e2e:reuse": "E2E_REUSE_EMULATOR=true playwright test",
    "emulator:start": "firebase emulators:start --only auth,firestore,functions --project saasgestaoescolar-test",
    "emulator:seed": "node scripts/seed-emulator.js",
    "seed:admins": "node scripts/seed-admins.js",
    "migrate": "node scripts/migrate-to-multitenant.js",
    "create:school": "node scripts/createSchool.js"
  },
  "dependencies": {
    "@sentry/react": "^10.51.0",
    "firebase": "^10.12.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.4",
    "@playwright/test": "^1.48.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.19",
    "dotenv": "^16.4.5",
    "firebase-admin": "^13.8.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.1",
    "vitest": "^4.1.4"
  }
}
