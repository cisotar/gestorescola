rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Leitura pública ─────────────────────────────────────────────────────
    match /meta/{doc}     { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    // ── Ausências: leitura pública; create/update bloqueados para slots de formação ──
    // CONTRATO OBRIGATÓRIO: qualquer sharedSeries de type === 'formation' criada
    // futuramente DEVE usar subjectId prefixado com "formation-" (ex: "formation-atpcg").
    // Essa convenção é a única garantia de que slots de formação nunca sejam gravados
    // como ausências substituíveis, independentemente do cliente ou do role do usuário.
    match /absences/{doc} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && !hasFormationSlot(request.resource.data.slots);
      allow update: if isAuthenticated() && !hasFormationSlot(request.resource.data.slots);
      allow delete: if isAuthenticated();
    }
    match /history/{doc}  { allow read: if isAuthenticated(); allow write: if isAdmin(); }

    // ── Professores: leitura pública; admin escreve; professor edita próprio perfil ──
    match /teachers/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow update: if request.auth != null
        && resource.data.email.lower() == request.auth.token.email.lower()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['celular', 'whatsapp', 'apelido', 'name', 'subjectIds', 'horariosSemana']);
    }

    // ── Horários: leitura pública; admin escreve; professor gerencia próprios slots ──
    // ownsProfile cobre professores aprovados (teacherId = teacher.id no Firestore)
    // request.auth.uid cobre professores pendentes (teacherId = user.uid no PendingPage)
    match /schedules/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow create: if request.auth != null
        && (request.resource.data.teacherId == request.auth.uid
            || ownsProfile(request.resource.data.teacherId));
      allow update: if request.auth != null
        && (resource.data.teacherId == request.auth.uid
            || ownsProfile(resource.data.teacherId));
      allow delete: if request.auth != null
        && (resource.data.teacherId == request.auth.uid
            || ownsProfile(resource.data.teacherId));
    }

    // ── Pendentes: admin lê/escreve; professor acessa apenas o próprio doc (por UID) ──
    match /pending_teachers/{docId} {
      allow read, write: if isAdmin()
        || (request.auth != null && request.auth.uid == docId);
    }

    // ── Ações pendentes: usuários autenticados criam, admins aprovam/rejeitam ──
    // Nota: isCoordinator() não funciona com IDs UUID dos teachers — a validação
    // de perfil é feita no lado JS (store guards). Qualquer usuário autenticado
    // pode criar; apenas admins podem ler/atualizar/deletar.
    match /pending_actions/{id} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Somente admins ───────────────────────────────────────────────────────
    // O ID do documento é o email em lowercase (ex: "contato.tarciso@gmail.com")
    match /admins/{doc} {
      allow read: if isAdmin()
        || (request.auth != null && doc == request.auth.token.email.lower());
      allow write: if isAdmin();
    }

    // ── Funções auxiliares ───────────────────────────────────────────────────
    function isAuthenticated() {
      return request.auth != null;
    }

    function ownsProfile(teacherId) {
      let teacherDoc = get(/databases/$(database)/documents/teachers/$(teacherId));
      return teacherDoc != null && teacherDoc.data.email.lower() == request.auth.token.email.lower();
    }

    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower()));
    }

    // Retorna true se o primeiro slot possui subjectId prefixado com "formation-".
    // Usado para bloquear create/update de absences com slots de formação.
    function hasFormationSlot(slots) {
      return slots.size() > 0
        && slots[0].subjectId.matches('formation-.*');
    }
  }
}
