rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Super-admins do SaaS ─────────────────────────────────────────────────
    // Document ID = email em lowercase (ex: "admin@gestorescolar.com.br")
    match /admins/{emailDoc} {
      allow read: if isSaasAdmin()
        || (request.auth != null
            && request.auth.token.email is string
            && emailDoc == request.auth.token.email.lower());
      allow write: if isSaasAdmin();
    }

    // ── Perfil global do usuário (mapa de escola → role/status) ─────────────
    // CRÍTICO — defesa em profundidade:
    // Toda mutação no campo `schools` é privilégio exclusivo das Cloud Functions
    // (Admin SDK bypassa rules). Cliente NÃO pode escrever schools sob hipótese
    // alguma — caso contrário, qualquer usuário autenticado promove a si mesmo
    // a admin de qualquer escola.
    //
    // Create: permitido pelo próprio uid SEM o campo schools (perfil inicial).
    // Update: permitido pelo próprio uid APENAS se não tocar em schools (campos
    //   de perfil pessoal — ex.: name, photoURL futuros). SaaS admin tem bypass
    //   total via /admins/, mas no fluxo atual SaaS admin também opera via
    //   Cloud Function — manter isSaasAdmin como escape de manutenção.
    // Delete: apenas SaaS admin.
    match /users/{uid} {
      allow read:   if request.auth != null && request.auth.uid == uid || isSaasAdmin();
      allow create: if isSaasAdmin()
        || (request.auth != null
            && request.auth.uid == uid
            && !('schools' in request.resource.data));
      allow update: if isSaasAdmin()
        || (request.auth != null
            && request.auth.uid == uid
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['schools']));
      allow delete: if isSaasAdmin();
    }

    // ── Documento raiz da escola ─────────────────────────────────────────────
    // Leitura liberada para qualquer autenticado: contém apenas nome/metadados,
    // sem dados sensíveis. Necessário para o fluxo de convite (/join/:slug)
    // onde o professor ainda não é membro mas precisa ler o nome da escola.
    // Create restrito ao SaaS admin: criação de escolas é privilégio do painel
    // SaaS, executado via Cloud Function ou pelo próprio painel admin.
    // Update segmentado: campos administrativos (status, adminEmail, deletedAt)
    // só podem ser alterados pelo SaaS admin; demais campos seguem isSchoolAdmin.
    match /schools/{schoolId} {
      allow read:   if isAuthenticated();
      allow create: if isSaasAdmin();
      allow update: if isSaasAdmin()
        || (isSchoolAdmin(schoolId)
            && !request.resource.data.diff(resource.data).affectedKeys()
                .hasAny(['status', 'adminEmail', 'deletedAt']));
      allow delete: if isSaasAdmin();
    }

    // ── Configuração da escola ───────────────────────────────────────────────
    // Leitura liberada também para pending: professor precisa ver matérias/segmentos
    // para preencher o formulário de cadastro na PendingPage.
    // Create restrito ao criador da escola (campo createdBy): garante que apenas
    // quem criou o documento schools/{schoolId} pode inicializar a config.
    match /schools/{schoolId}/config/{doc} {
      allow read:   if isMemberOf(schoolId) || isSaasAdmin() || isPendingIn(schoolId);
      allow create: if isSaasAdmin()
        || (request.auth != null
            && exists(/databases/$(database)/documents/schools/$(schoolId))
            && request.auth.uid == get(/databases/$(database)/documents/schools/$(schoolId)).data.createdBy);
      allow update: if isSchoolAdmin(schoolId);
      allow delete: if isSchoolAdmin(schoolId);
    }

    // ── Professores ──────────────────────────────────────────────────────────
    match /schools/{schoolId}/teachers/{docId} {
      // Leitura: membros da escola, SaaS admin, ou o próprio usuário cujo email
      // bate com o teacher doc (necessário para auto-reconciliação quando
      // users/{uid} foi perdido mas teacher já existe aprovado).
      allow read:  if isMemberOf(schoolId)
        || isSaasAdmin()
        || (request.auth != null
            && request.auth.token.email is string
            && resource.data.email is string
            && resource.data.email.lower() == request.auth.token.email.lower()
            && !isSchoolSuspended(schoolId));
      allow write: if isSchoolAdmin(schoolId);
      // Professor edita apenas campos de perfil do próprio documento
      allow update: if request.auth != null
        && request.auth.token.email is string
        && resource.data.email is string
        && resource.data.email.lower() == request.auth.token.email.lower()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['celular', 'whatsapp', 'apelido', 'name', 'subjectIds', 'horariosSemana']);
    }

    // ── Grade horária ────────────────────────────────────────────────────────
    // Admin/school-admin: escrita total.
    // Teacher: cria slot para si mesmo; atualiza/deleta slots próprios.
    // ownsProfileIn cobre professores cujo teacherId != auth.uid (ID interno != UID do Auth).
    match /schools/{schoolId}/schedules/{docId} {
      allow read:  if isMemberOf(schoolId) || isSaasAdmin() || isPendingIn(schoolId);
      allow write: if isSchoolAdmin(schoolId);
      // Membros aprovados criam para si ou para teacher cujo perfil possuem.
      // Pending teachers podem criar APENAS para si (teacherId == auth.uid),
      // permitindo preencher a grade horária na PendingPage. Cloud Function
      // approveTeacher migra esses schedules do pendingUid para o teacher.id real.
      allow create: if (isMemberOf(schoolId)
        && (request.resource.data.teacherId == request.auth.uid
            || ownsProfileIn(schoolId, request.resource.data.teacherId)))
        || (isPendingIn(schoolId)
            && request.resource.data.teacherId == request.auth.uid);
      allow update: if (isMemberOf(schoolId)
        && (resource.data.teacherId == request.auth.uid
            || ownsProfileIn(schoolId, resource.data.teacherId))
        && (request.resource.data.teacherId == request.auth.uid
            || ownsProfileIn(schoolId, request.resource.data.teacherId)))
        || (isPendingIn(schoolId)
            && resource.data.teacherId == request.auth.uid
            && request.resource.data.teacherId == request.auth.uid);
      allow delete: if (isMemberOf(schoolId)
        && (resource.data.teacherId == request.auth.uid
            || ownsProfileIn(schoolId, resource.data.teacherId)))
        || (isPendingIn(schoolId)
            && resource.data.teacherId == request.auth.uid);
    }

    // ── Ausências ────────────────────────────────────────────────────────────
    // Leitura: qualquer membro da escola.
    // Escrita: bloqueada para o cliente — exclusivamente via Cloud Function
    // (createAbsence, updateAbsence, deleteAbsence) que usa Admin SDK e
    // valida role coordinator/admin via verifyCoordinatorOrAdmin().
    // O guard hasFormationSlot permanece como defesa em profundidade:
    // se a Cloud Function for bypassada, a rule bloqueia.
    match /schools/{schoolId}/absences/{docId} {
      allow read:   if isMemberOf(schoolId) || isSaasAdmin();
      allow create: if isSchoolAdmin(schoolId)
        && !hasFormationSlot(request.resource.data.slots);
      allow update: if isSchoolAdmin(schoolId)
        && !hasFormationSlot(request.resource.data.slots);
      allow delete: if isSchoolAdmin(schoolId);
    }

    // ── Histórico de substituições ───────────────────────────────────────────
    // Registros imutáveis criados apenas por admin/school-admin.
    match /schools/{schoolId}/history/{docId} {
      allow read:  if isMemberOf(schoolId) || isSaasAdmin();
      allow write: if isSchoolAdmin(schoolId);
    }

    // ── Usuários removidos (marcação anti-recriação de pending) ─────────────
    // Gravado APENAS por Cloud Function (removeTeacherFromSchool). Cliente lê
    // o próprio doc para detectar revogação e bloquear nova solicitação de
    // acesso. Admins da escola e SaaS admin também podem ler para auditoria.
    match /schools/{schoolId}/removed_users/{docId} {
      allow read:   if (request.auth != null && request.auth.uid == docId)
                    || isSchoolAdmin(schoolId)
                    || isSaasAdmin();
      allow write:  if false; // apenas Admin SDK via Cloud Function
    }

    // ── Solicitações de acesso pendentes ─────────────────────────────────────
    // Leitura: admin, coordenador ou o próprio dono do doc.
    // Escrita: o próprio dono pode criar/atualizar (campos de perfil pessoal).
    // Coordenadores podem atualizar (status de aprovação/rejeição) sem Admin SDK.
    // Aprovação/rejeição definitiva é feita via Cloud Function (approveTeacher/
    // rejectTeacher) que usa Admin SDK e bypassa rules — este allow update para
    // coordenadores cobre apenas o fluxo de coordenação direta.
    match /schools/{schoolId}/pending_teachers/{docId} {
      allow read:  if isSchoolAdmin(schoolId)
        || isCoordinator(schoolId)
        || (request.auth != null && request.auth.uid == docId);
      allow create: if request.auth != null && request.auth.uid == docId;
      allow update: if (request.auth != null && request.auth.uid == docId)
        || isCoordinator(schoolId);
      allow delete: if isSchoolAdmin(schoolId);
    }

    // ── Slugs de escola (coleção raiz — leitura pública pré-autenticação) ──────
    // Leitura: pública (usada na JoinPage antes de o usuário se autenticar).
    // Create: qualquer autenticado pode criar — necessário para o onboarding, pois
    // no momento da criação o usuário ainda não é schoolAdmin (users/{uid}.schools
    // ainda não foi populado). A unicidade é garantida pelo Firestore (create falha
    // se o documento já existe). O campo schoolId não é exigido aqui — o criador
    // acabou de criar a escola e ainda não tem o vínculo que isSchoolAdmin requer.
    // Update/delete: somente admin da escola referenciada no payload ou super-admin.
    // ATENÇÃO: o campo schoolId deve estar presente no payload ao atualizar
    // um slug; sem ele, isSchoolAdmin(null) retorna false e a escrita é negada.
    // Esta coleção fica no nível raiz do Firestore — não é subcoleção de schools/
    // — pois o slug é o único identificador disponível antes do login.
    match /school_slugs/{slug} {
      allow read:   if true;
      allow create: if isAuthenticated();
      allow update: if isSchoolAdmin(request.resource.data.schoolId) || isSaasAdmin();
      allow delete: if isSchoolAdmin(resource.data.schoolId) || isSaasAdmin();
    }

    // ── Ações pendentes de coordenadores ─────────────────────────────────────
    match /schools/{schoolId}/pending_actions/{id} {
      allow read:           if isSchoolAdmin(schoolId) || isSaasAdmin();
      allow create:         if isMemberOf(schoolId);
      allow update, delete: if isSchoolAdmin(schoolId) || isSaasAdmin();
    }

    // ── Log de auditoria (imutável) ───────────────────────────────────────────
    match /schools/{schoolId}/admin_actions/{id} {
      allow read:           if isSchoolAdmin(schoolId) || isSaasAdmin();
      allow create:         if isSchoolAdmin(schoolId) || isSaasAdmin();
      allow update, delete: if false;
    }

    // ══════════════════════════════════════════════════════════════════════════
    // Funções auxiliares
    // ══════════════════════════════════════════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    // Verifica se o uid autenticado possui documento em /admins/ (super-admin SaaS).
    // Usa `request.auth.token.email is string` para null-safety:
    // evita "Null value error" quando o campo email não está disponível no token.
    function isSaasAdmin() {
      return isAuthenticated()
        && request.auth.token.email is string
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email.lower()));
    }

    // Verifica se o usuário é membro aprovado da escola.
    // Usa `in` operator para verificar existência de chaves antes de acessá-las.
    // Retorna false se o documento users/{uid} não existir ou se schools não tiver a chave.
    // Também retorna false se schools/{schoolId}.status == 'suspended'.
    function isMemberOf(schoolId) {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated()
        && exists(userPath)
        && 'schools' in get(userPath).data
        && schoolId in get(userPath).data.schools
        && (get(userPath).data.schools[schoolId].status == 'approved'
            || get(userPath).data.schools[schoolId].status == 'active')
        && !isSchoolSuspended(schoolId);
    }

    // Retorna true se a escola existe e tem status == 'suspended'.
    // Escola sem campo status (ou inexistente) é tratada como "não suspensa"
    // por retrocompatibilidade com docs criados antes da migração.
    // Usa `in` para verificar existência do campo antes de acessá-lo.
    function isSchoolSuspended(schoolId) {
      let schoolPath = /databases/$(database)/documents/schools/$(schoolId);
      return exists(schoolPath)
        && 'status' in get(schoolPath).data
        && get(schoolPath).data.status == 'suspended';
    }

    // Alias legível — semanticamente equivalente a isMemberOf.
    function isSchoolMember(schoolId) {
      return isMemberOf(schoolId);
    }

    // Verifica se o usuário tem solicitação pendente na escola.
    // Usado para liberar leitura de config (matérias/segmentos) na PendingPage.
    function isPendingIn(schoolId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/schools/$(schoolId)/pending_teachers/$(request.auth.uid));
    }

    // Verifica se o usuário é admin da escola ou super-admin SaaS.
    // Usa `in` operator para verificar existência de chaves antes de acessá-las.
    function isSchoolAdmin(schoolId) {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isSaasAdmin()
        || (isAuthenticated()
            && exists(userPath)
            && 'schools' in get(userPath).data
            && schoolId in get(userPath).data.schools
            && get(userPath).data.schools[schoolId].status == 'approved'
            && get(userPath).data.schools[schoolId].role == 'admin'
            && !isSchoolSuspended(schoolId));
    }

    // Verifica se o usuário é coordenador (role 'coordinator' ou 'teacher-coordinator') da escola.
    // Coordenadores podem ler pending_teachers e atualizar status de aprovação.
    // Usa `in` operator para verificar existência de chaves antes de acessá-las.
    function isCoordinator(schoolId) {
      let userPath = /databases/$(database)/documents/users/$(request.auth.uid);
      return isAuthenticated()
        && exists(userPath)
        && 'schools' in get(userPath).data
        && schoolId in get(userPath).data.schools
        && (get(userPath).data.schools[schoolId].role == 'coordinator'
            || get(userPath).data.schools[schoolId].role == 'teacher-coordinator')
        && !isSchoolSuspended(schoolId);
    }

    // Verifica se o usuário autenticado é dono do perfil de teacher em uma escola específica.
    // Usado em schedules para cobrir o caso em que teacherId != auth.uid
    // (Document ID do teacher é uid() interno, diferente do Firebase Auth UID).
    // Usa `is string` para null-safety no campo email.
    function ownsProfileIn(schoolId, teacherId) {
      let teacherPath = /databases/$(database)/documents/schools/$(schoolId)/teachers/$(teacherId);
      return isAuthenticated()
        && request.auth.token.email is string
        && exists(teacherPath)
        && get(teacherPath).data.email is string
        && get(teacherPath).data.email.lower() == request.auth.token.email.lower();
    }

    // Retorna true se qualquer slot nas posições 0..4 tem subjectId prefixado com "formation-".
    // Firestore rules não têm .some() nativo — verificação explícita posição a posição.
    // CONTRATO: todo sharedSeries de type === 'formation' deve usar subjectId "formation-*".
    function hasFormationSlot(slots) {
      return slots.size() > 0 && (
        slots[0].subjectId.matches('formation-.*') ||
        (slots.size() > 1 && slots[1].subjectId.matches('formation-.*')) ||
        (slots.size() > 2 && slots[2].subjectId.matches('formation-.*')) ||
        (slots.size() > 3 && slots[3].subjectId.matches('formation-.*')) ||
        (slots.size() > 4 && slots[4].subjectId.matches('formation-.*'))
      );
    }
  }
}
