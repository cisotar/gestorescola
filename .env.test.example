# Testes E2E com Playwright — Template
# Copie este arquivo para .env.test (`cp .env.test.example .env.test`).
# Os valores abaixo são suficientes para rodar contra Firebase Emulators
# (não precisa preencher credenciais reais).

# === Flag mestre: conecta SDK aos emulators ===
VITE_USE_FIREBASE_EMULATOR=true
VITE_FIREBASE_EMULATOR_HOST=localhost

# === Firebase config (valores fake, válidos só para o emulator) ===
VITE_FIREBASE_API_KEY=fake-api-key-for-emulator
VITE_FIREBASE_AUTH_DOMAIN=localhost
VITE_FIREBASE_PROJECT_ID=saasgestaoescolar-test
VITE_FIREBASE_STORAGE_BUCKET=saasgestaoescolar-test.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:test

# === Variáveis usadas pelos scripts Node (seed, globalSetup) ===
FIREBASE_PROJECT_ID=saasgestaoescolar-test
FIRESTORE_EMULATOR_HOST=localhost:8080
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FUNCTIONS_EMULATOR_HOST=localhost:5001

# === Playwright ===
BASE_URL=http://localhost:5173
HEADLESS=true
SLOW_MO=0
TIMEOUT=30000

# Setar como true para reusar emulator que já está rodando em outra aba.
# E2E_REUSE_EMULATOR=true
