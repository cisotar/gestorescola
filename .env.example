VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_SUPER_ADMIN_EMAIL=
# DSN público do projeto Sentry (não é secret — pode aparecer em builds públicos).
# Criar no dashboard Sentry em Settings > Projects > <projeto> > Client Keys.
# Em desenvolvimento, o SDK fica desabilitado (import.meta.env.PROD === false).
VITE_SENTRY_DSN=

# ─── Credenciais para scripts Node.js em scripts/ ─────────────────────────────
# Estas variáveis NÃO são prefixadas com VITE_ — não vão para o bundle do frontend.
# Necessárias apenas para executar scripts administrativos localmente.
#
# Opção A (recomendada): conteúdo JSON da service account inline.
# Obter via: gcloud secrets versions access latest \
#   --secret=FIREBASE_SERVICE_ACCOUNT_KEY --project=saasgestaoescolar
SERVICE_ACCOUNT_KEY_JSON=
#
# Opção B: caminho para arquivo JSON de service account em disco.
# O arquivo deve estar FORA do diretório do projeto para evitar commit acidental.
# Exemplo: /home/usuario/.config/gcloud/sa-saasgestaoescolar.json
GOOGLE_APPLICATION_CREDENTIALS=
